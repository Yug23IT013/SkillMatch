# ─── Next.js build output ─────────────────────────────────────────────────────
.next/
out/
build/
dist/

# ─── Dependencies ─────────────────────────────────────────────────────────────
node_modules/
.npm/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# ─── Environment / Secrets ────────────────────────────────────────────────────
.env
.env.local
.env.production
.env.staging
.env.*.local
# Allow example template files
!.env.example
!.env.local.example
*.pem
*.key

# ─── TypeScript ───────────────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ─── Package manager lock files (keep only one) ───────────────────────────────
# Uncomment the one you DON'T use:
# yarn.lock
# pnpm-lock.yaml

# ─── Testing ──────────────────────────────────────────────────────────────────
coverage/
.nyc_output/

# ─── Storybook ────────────────────────────────────────────────────────────────
storybook-static/

# ─── IDE / OS ─────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.DS_Store
Thumbs.db
desktop.ini

# ─── Misc ─────────────────────────────────────────────────────────────────────
*.log
.cache/
