PORT=5000
MONGODB_URI=mongodb://localhost:27017/skillmatch
JWT_SECRET=replace-with-64-char-random-hex-run-node-crypto-randomBytes
JWT_EXPIRE=7d
ML_SERVICE_URL=http://localhost:8000
NODE_ENV=development
# Password used when running `node seed.js` to create demo accounts
SEED_PASSWORD=change-me-before-seeding

# Email Configuration (for Nodemailer)
# For Gmail:
#   1. Enable 2-Factor Authentication on your Google account
#   2. Generate an App Password at: https://myaccount.google.com/apppasswords
#   3. Use the App Password (16 characters with spaces) as EMAIL_PASSWORD
# For other providers:
#   - Outlook: smtp.office365.com, port 587
#   - Yahoo: smtp.mail.yahoo.com, port 587
#   - Custom SMTP: Update host and port accordingly
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password-here

# Frontend URL (used in email links)
FRONTEND_URL=http://localhost:3000
